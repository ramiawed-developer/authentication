{
  "name": "authentication",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "contracts:build": "npm run build --workspace @authentication/contracts",
    "contracts:test": "npm run test --workspace @authentication/contracts",
    "contracts:typecheck": "npm run typecheck --workspace @authentication/contracts",
    "backend:lint": "npm run lint --workspace backend",
    "backend:typecheck": "npm run typecheck --workspace backend",
    "backend:test": "npm run test --workspace backend",
    "backend:build": "npm run build --workspace backend",
    "frontend:lint": "npm run lint --workspace frontend",
    "frontend:typecheck": "npm run typecheck --workspace frontend",
    "frontend:test": "npm run test --workspace frontend",
    "frontend:build": "npm run build --workspace frontend",
    "lint": "npm run backend:lint && npm run frontend:lint",
    "typecheck": "npm run contracts:build && npm run contracts:typecheck && npm run backend:typecheck && npm run frontend:typecheck",
    "test": "npm run contracts:test && npm run backend:test && npm run frontend:test",
    "build": "npm run contracts:build && npm run backend:build && npm run frontend:build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "prettier": "^3.8.4"
  }
}
